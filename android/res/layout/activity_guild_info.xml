<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/background_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp">

        <!-- TITLE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_gradient"
            android:padding="14dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/txtGuildName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Guild"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- GUILD INFO CARD -->
        <LinearLayout
            android:id="@+id/layoutGuildInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_gradient"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Stats Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="Guild Stats"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:background="#12000000"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/txtMemberCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Members: 0"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/txtEnemiesKilled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enemies Killed: 0"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/txtWins"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wins: 0"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/txtAttempts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Attempts: 0"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Members Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:orientation="vertical"
                    android:paddingStart="8dp">

                    <TextView
                        android:id="@+id/txtMembersTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="Guild Members"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerGuildMembers"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:background="#12000000"
                        android:clipToPadding="false"
                        android:padding="4dp"
                        android:scrollbars="vertical" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/txtGuildChatTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"
                    android:text="Guild Chat"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerGuildChat"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:background="#12000000"
                    android:clipToPadding="false"
                    android:padding="8dp"
                    android:scrollbars="vertical" />

                <TextView
                    android:id="@+id/txtGuildChatStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Chat unavailable"
                    android:textColor="#FFB3B3B3"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layoutGuildChatInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edtGuildMessage"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="#22000000"
                        android:ems="10"
                        android:hint="Write a message..."
                        android:inputType="textCapSentences|textMultiLine"
                        android:maxLength="300"
                        android:paddingHorizontal="12dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#99FFFFFF" />

                    <Button
                        android:id="@+id/btnSendGuildMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="72dp"
                        android:text="Send" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnLeaveGuild"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:text="Leave Guild" />

                    <Button
                        android:id="@+id/btnDeleteGuild"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:text="Delete Guild"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#B00020"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

        <!-- NO GUILD CARD -->
        <LinearLayout
            android:id="@+id/layoutNoGuild"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="14dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="520dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You are not in a guild"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnCreateGuild"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Create Guild"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnJoinGuild"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Join Guild" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
